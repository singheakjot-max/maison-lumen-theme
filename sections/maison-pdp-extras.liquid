{% render 'maison-vars' %}
<style>

/* ===== ml-smooth-divine ===== */
.ml-divine { padding: 80px 48px; background: var(--ml-cream); }
  .ml-divine-grid { max-width: 1080px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
  .ml-divine h2 { font-family: var(--ml-serif); font-size: clamp(34px, 4.5vw, 50px); font-weight: 300; line-height: 1; letter-spacing: -0.02em; color: var(--ml-ink); margin-bottom: 16px; }
  .ml-divine h2 em { font-style: italic; font-weight: 300; }
  .ml-divine p { font-size: 14px; color: var(--ml-charcoal); line-height: 1.7; max-width: 400px; }
  .ml-divine-visual { background: var(--ml-amber-bg); border-radius: 4px; padding: 40px 32px; aspect-ratio: 1.1; display: flex; flex-direction: column; justify-content: space-between; }
  .ml-divine-visual-head { display: flex; gap: 20px; align-items: center; }
  .ml-divine-visual-head img { max-height: 200px; }
  .ml-divine-visual h3 { font-family: var(--ml-serif); font-size: 26px; font-weight: 300; line-height: 1.1; color: var(--ml-ink); }
  .ml-divine-visual h3 em { font-style: italic; font-weight: 300; }
  .ml-divine-zones { display: flex; gap: 24px; justify-content: space-around; margin-top: 20px; }
  .ml-divine-zone { text-align: center; }
  .ml-divine-zone-svg {
    width: 60px;
    height: 60px;
    margin: 0 auto 6px;
    color: var(--ml-brown);
  }
  .ml-divine-zone-lbl {
    font-family: var(--ml-body);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ml-brown);
    font-weight: 600;
  }
  @media (max-width: 900px) {
    .ml-divine { padding: 56px 20px; }
    .ml-divine-grid { grid-template-columns: 1fr; gap: 32px; }
    .ml-divine-visual { aspect-ratio: auto; padding: 28px 20px; }
  }

/* ===== ml-big-testimonial ===== */
.ml-big-test { padding: 80px 48px; background: var(--ml-white); }
  .ml-big-test-grid { max-width: 1080px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
  .ml-big-test-card {
    background: var(--ml-honey-deep);
    color: var(--ml-cream);
    aspect-ratio: 1;
    border-radius: 4px;
    overflow: hidden;
    position: relative;
    display: flex;
  }
  .ml-big-test-quote {
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    flex: 0 0 60%;
  }
  .ml-big-test-photo {
    flex: 1;
    background: var(--ml-tan-deep);
    background-size: cover;
    background-position: center;
  }
  .ml-big-test-brand { font-family: var(--ml-serif); font-size: 13px; letter-spacing: 0.1em; color: var(--ml-cream); margin-bottom: 16px; }
  .ml-big-test-card blockquote {
    font-family: var(--ml-serif);
    font-size: clamp(20px, 2.2vw, 28px);
    font-weight: 400;
    line-height: 1.2;
    color: var(--ml-cream);
    margin: 0;
  }
  .ml-big-test-card blockquote strong, .ml-big-test-card blockquote .hl {
    background: var(--ml-cream);
    color: var(--ml-ink);
    padding: 0 4px 2px;
    font-weight: 400;
    font-style: italic;
  }
  .ml-big-test-text h2 {
    font-family: var(--ml-serif);
    font-size: clamp(34px, 4vw, 48px);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.015em;
    color: var(--ml-ink);
    margin-bottom: 18px;
  }
  .ml-big-test-text h2 em { font-style: italic; font-weight: 300; }
  .ml-big-test-text p { font-size: 14px; color: var(--ml-charcoal); line-height: 1.7; max-width: 440px; }
  @media (max-width: 900px) {
    .ml-big-test { padding: 56px 20px; }
    .ml-big-test-grid { grid-template-columns: 1fr; gap: 28px; }
    .ml-big-test-card { aspect-ratio: 4/3; }
  }

/* ===== ml-embrace ===== */
.ml-embrace { padding: 80px 48px; background: var(--ml-cream); }
  .ml-embrace-grid { max-width: 1080px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1.1fr; gap: 56px; align-items: center; }
  .ml-embrace h2 { font-family: var(--ml-serif); font-size: clamp(34px, 4.5vw, 50px); font-weight: 300; line-height: 1; letter-spacing: -0.02em; color: var(--ml-ink); margin-bottom: 18px; }
  .ml-embrace h2 em { font-style: italic; font-weight: 300; }
  .ml-embrace p { font-size: 14px; color: var(--ml-charcoal); line-height: 1.7; max-width: 460px; }
  .ml-embrace-img { aspect-ratio: 5/4; background: var(--ml-tan); border-radius: 4px; overflow: hidden; }
  .ml-embrace-img img { width: 100%; height: 100%; object-fit: cover; }
  @media (max-width: 900px) {
    .ml-embrace { padding: 56px 20px; }
    .ml-embrace-grid { grid-template-columns: 1fr; gap: 28px; }
  }

/* ===== ml-pdp-trust ===== */
.ml-pdp-trust { padding: 36px 48px; background: var(--ml-white); border-top: 1px solid var(--ml-line); border-bottom: 1px solid var(--ml-line); }
  .ml-pdp-trust-grid { max-width: 980px; margin: 0 auto; display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .ml-pdp-trust-cell { text-align: center; padding: 0 16px; }
  .ml-pdp-trust-icon { font-size: 18px; margin-bottom: 6px; color: var(--ml-ink); }
  .ml-pdp-trust-cell h5 { font-family: var(--ml-serif); font-size: 15px; font-weight: 500; color: var(--ml-ink); margin-bottom: 4px; }
  .ml-pdp-trust-cell p { font-size: 12px; color: var(--ml-grey); line-height: 1.5; }
  @media (max-width: 900px) {
    .ml-pdp-trust { padding: 28px 16px; }
    .ml-pdp-trust-grid { grid-template-columns: 1fr; gap: 20px; }
  }

/* ===== ml-reviews-wall ===== */
.ml-revwall { padding: 80px 48px; background: var(--ml-white); }
  .ml-revwall-head { text-align: center; max-width: 880px; margin: 0 auto 36px; }
  .ml-revwall-head .stars { color: var(--ml-honey-deep); font-size: 18px; letter-spacing: 0.1em; margin-bottom: 8px; }
  .ml-revwall-head h2 { font-family: var(--ml-serif); font-size: clamp(28px, 3vw, 38px); font-weight: 400; color: var(--ml-ink); margin-bottom: 6px; }
  .ml-revwall-head a { font-size: 12px; color: var(--ml-charcoal); border-bottom: 1px solid var(--ml-ink); padding-bottom: 1px; }
  .ml-revwall-grid {
    max-width: 1180px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 6px;
  }
  .ml-rev {
    aspect-ratio: 1;
    position: relative;
    overflow: hidden;
    border-radius: 2px;
    background: var(--ml-tan);
  }
  .ml-rev.text { background: var(--ml-cream); padding: 14px; display: flex; flex-direction: column; gap: 4px; border: 1px solid var(--ml-line); }
  .ml-rev.text .ml-rev-stars { color: var(--ml-honey-deep); font-size: 11px; letter-spacing: 0.05em; }
  .ml-rev.text .ml-rev-author { font-size: 11px; font-weight: 700; color: var(--ml-ink); display: flex; align-items: center; gap: 4px; }
  .ml-rev.text .ml-rev-verified { font-size: 9px; color: var(--ml-forest); font-weight: 600; }
  .ml-rev.text .ml-rev-date { font-size: 10px; color: var(--ml-grey); }
  .ml-rev.text p { font-size: 11px; color: var(--ml-charcoal); line-height: 1.5; }
  .ml-rev.photo img { width: 100%; height: 100%; object-fit: cover; }
  .ml-rev.photo.video::after {
    content: '▶';
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    color: var(--ml-cream);
    background: rgba(0,0,0,0.5);
    width: 36px; height: 36px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    padding-left: 3px; font-size: 12px;
  }
  @media (max-width: 900px) { .ml-revwall { padding: 48px 16px; } .ml-revwall-grid { grid-template-columns: repeat(3, 1fr); } }

/* ===== ml-clinicians ===== */
.ml-clin { padding: 80px 48px; background: var(--ml-white); border-top: 1px solid var(--ml-line); }
  .ml-clin-head { text-align: center; max-width: 880px; margin: 0 auto 36px; }
  .ml-clin-eyebrow {
    display: inline-block;
    font-family: var(--ml-body);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--ml-brown);
    padding: 4px 0;
    border-top: 1px solid var(--ml-line);
    border-bottom: 1px solid var(--ml-line);
    margin-bottom: 16px;
  }
  .ml-clin h2 {
    font-family: var(--ml-serif);
    font-size: clamp(28px, 3vw, 38px);
    font-weight: 400;
    color: var(--ml-ink);
    margin-bottom: 8px;
  }
  .ml-clin-head p { font-size: 12px; color: var(--ml-grey); }
  .ml-clin-head a { color: var(--ml-ink); border-bottom: 1px solid var(--ml-ink); padding-bottom: 1px; }
  .ml-clin-list { max-width: 1080px; margin: 0 auto; }
  .ml-clinician {
    display: grid;
    grid-template-columns: 64px 200px 1fr;
    gap: 24px;
    padding: 24px 0;
    border-bottom: 1px solid var(--ml-line);
    align-items: start;
  }
  .ml-clinician-avatar {
    width: 64px; height: 64px;
    border-radius: 50%;
    background: var(--ml-tan);
    overflow: hidden;
    flex-shrink: 0;
  }
  .ml-clinician-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .ml-clinician-meta-name {
    font-family: var(--ml-body);
    font-size: 13px;
    font-weight: 700;
    color: var(--ml-ink);
    display: flex; align-items: center; gap: 4px;
    margin-bottom: 4px;
  }
  .ml-clinician-meta-name .v { font-size: 10px; color: var(--ml-forest); font-weight: 600; }
  .ml-clinician-meta-line { font-size: 11px; color: var(--ml-grey); margin-bottom: 2px; display: flex; justify-content: space-between; }
  .ml-clinician-meta-line strong { color: var(--ml-ink); font-weight: 500; }
  .ml-clinician-content h5 {
    font-family: var(--ml-serif);
    font-size: 14px;
    font-weight: 500;
    color: var(--ml-ink);
    margin-bottom: 6px;
  }
  .ml-clinician-content p { font-size: 12px; color: var(--ml-charcoal); line-height: 1.55; margin-bottom: 6px; }
  .ml-clinician-highlights {
    font-size: 10px;
    color: var(--ml-grey);
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 4px;
  }
  .ml-clinician-highlights .h-label { color: var(--ml-ink); font-weight: 600; margin-right: 6px; }
  .ml-clinician-highlights .h-item::before { content: '☐'; margin-right: 4px; color: var(--ml-grey); }
  .ml-clin-foot { text-align: center; margin-top: 24px; }
  .ml-clin-foot small { font-size: 10px; color: var(--ml-grey); }
  @media (max-width: 900px) {
    .ml-clin { padding: 48px 16px; }
    .ml-clinician { grid-template-columns: 1fr; gap: 12px; }
  }

</style>

<!-- ===== ml-smooth-divine ===== -->
<section class="ml-section ml-divine">
  <div class="ml-divine-grid">
    <div>
      <h2>{{ section.settings.divine_heading | default: '<p>Smooth & Fine.<br>So <em>Divine.</em></p>' }}</h2>
      <p>{{ section.settings.divine_body | default: 'Pure, unadulterated fine ingredients make this body oil suitable for all skin types and ages. Visibly glowing and plumper skin in days.' }}</p>
    </div>
    <div class="ml-divine-visual">
      <div class="ml-divine-visual-head">
        {% if section.settings.divine_bottle_image %}<img src="{{ section.settings.divine_bottle_image | image_url: width: 400 }}" alt="">{% endif %}
        <h3>{{ section.settings.divine_visual_heading | default: '<p>That Firms, Plumps & <em>Hydrates</em></p>' }}</h3>
      </div>
      <div class="ml-divine-zones">
        {% for block in section.blocks %}
          <div class="ml-divine-zone" {{ block.shopify_attributes }}>
            <svg class="ml-divine-zone-svg" viewBox="0 0 60 60" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              {% case block.settings.zone %}
                {% when 'arms' %}
                  <path d="M22 8 L22 38 M38 8 L38 38 M22 38 Q22 50 26 54 M38 38 Q38 50 34 54"/>
                {% when 'chest' %}
                  <path d="M14 18 L46 18 M14 18 Q14 30 22 36 Q30 42 38 36 Q46 30 46 18"/>
                  <path d="M22 24 Q26 27 30 24" /><path d="M30 24 Q34 27 38 24"/>
                {% when 'thighs' %}
                  <path d="M22 6 L22 50 M38 6 L38 50 M18 50 L26 56 M34 56 L42 50"/>
                {% when 'tums' %}
                  <path d="M16 14 Q16 32 30 36 Q44 32 44 14 M22 24 Q30 28 38 24"/>
                {% else %}
                  <circle cx="30" cy="30" r="20"/>
              {% endcase %}
            </svg>
            <div class="ml-divine-zone-lbl">{{ block.settings.label }}</div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<!-- ===== ml-big-testimonial ===== -->
<section class="ml-section ml-big-test">
  <div class="ml-big-test-grid">
    <div class="ml-big-test-card">
      <div class="ml-big-test-quote">
        <div class="ml-big-test-brand">MAISON LUMEN</div>
        <blockquote>{{ section.settings.bigtest_quote | default: '<p>"This body oil smells amazing. <span class="hl">My skin drinks it up</span> and feels <span class="hl">a lot firmer.</span> Dry and loose skin is a thing of the past."</p>' }}</blockquote>
      </div>
      <div class="ml-big-test-photo" {% if section.settings.bigtest_photo %}style="background-image: url('{{ section.settings.bigtest_photo | image_url: width: 800 }}');"{% endif %}></div>
    </div>
    <div class="ml-big-test-text">
      <h2>{{ section.settings.bigtest_heading | default: '<p>Loved by <em>380,000+</em><br>Women Just Like You</p>' }}</h2>
      <p>{{ section.settings.bigtest_body | default: 'Oils penetrate the skin far deeper than lotions and creams. They provide a nourishment and hydration that is unparalleled. Feel confident in your body through nature''s delights.' }}</p>
    </div>
  </div>
</section>

<!-- ===== ml-embrace ===== -->
<section class="ml-section ml-embrace">
  <div class="ml-embrace-grid">
    <div>
      <h2>{{ section.settings.embrace_heading | default: '<p>Embrace Your Body,<br>Radiate Your <em>Confidence.</em></p>' }}</h2>
      <p>{{ section.settings.embrace_body | default: 'Our Magic Body Elixir is your secret weapon for achieving the smooth, toned, and radiant skin you''ve always dreamed of. Packed with powerful natural ingredients like Patchouli, Rosehip and Geranium this silky elixir deeply nourishes, firms, and rejuvenates, helping you rediscover your most confident, sexy self at any age.' }}</p>
    </div>
    <div class="ml-embrace-img">
      {% if section.settings.embrace_image %}<img src="{{ section.settings.embrace_image | image_url: width: 1400 }}" alt="">{% endif %}
    </div>
  </div>
</section>

<!-- ===== ml-pdp-trust ===== -->
<section class="ml-section ml-pdp-trust">
  <div class="ml-pdp-trust-grid">
    {% for block in section.blocks %}
      <div class="ml-pdp-trust-cell" {{ block.shopify_attributes }}>
        <div class="ml-pdp-trust-icon">{{ block.settings.icon | default: '✦' }}</div>
        <h5>{{ block.settings.title }}</h5>
        <p>{{ block.settings.body }}</p>
      </div>
    {% endfor %}
  </div>
</section>

<!-- ===== ml-reviews-wall ===== -->
<section class="ml-section ml-revwall" id="reviews">
  <div class="ml-revwall-head">
    <div class="stars">★★★★★</div>
    <h2>{{ section.settings.reviews_heading | default: '18,402 Reviews' }}</h2>
    {% if section.settings.reviews_cta_text != blank %}<a href="{{ section.settings.reviews_cta_link | default: '#' }}">{{ section.settings.reviews_cta_text }}</a>{% endif %}
  </div>
  <div class="ml-revwall-grid">
    {% for block in section.blocks %}
      {% if block.type == 'photo' or block.type == 'video' %}
        <div class="ml-rev photo {% if block.type == 'video' %}video{% endif %}" {{ block.shopify_attributes }}>
          {% if block.settings.image %}<img src="{{ block.settings.image | image_url: width: 600 }}" alt="">{% endif %}
        </div>
      {% else %}
        <div class="ml-rev text" {{ block.shopify_attributes }}>
          <div class="ml-rev-author">{{ block.settings.author }} {% if block.settings.verified %}<span class="ml-rev-verified">✓ Verified</span>{% endif %}</div>
          <div class="ml-rev-date">{{ block.settings.date }}</div>
          <div class="ml-rev-stars">★★★★★</div>
          <p>{{ block.settings.body }}</p>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

<!-- ===== ml-clinicians ===== -->
<section class="ml-section ml-clin">
  <div class="ml-clin-head">
    <div class="ml-clin-eyebrow">{{ section.settings.clin_eyebrow | default: 'Clinician Reviews' }}</div>
    <h2>{{ section.settings.clin_heading | default: 'Independent Clinician Evaluations' }}</h2>
    <p>{{ section.settings.clin_subtitle | default: 'Clinicians receive product samples and are never compensated to submit evaluations.' }} {% if section.settings.clin_learn_link != blank %}<a href="{{ section.settings.clin_learn_link }}">Learn more</a>{% endif %}</p>
  </div>
  <div class="ml-clin-list">
    {% for block in section.blocks %}
      <div class="ml-clinician" {{ block.shopify_attributes }}>
        <div class="ml-clinician-avatar">
          {% if block.settings.image %}<img src="{{ block.settings.image | image_url: width: 200 }}" alt="">{% endif %}
        </div>
        <div>
          <div class="ml-clinician-meta-name">{{ block.settings.name }} <span class="v">✓ Verified clinician</span></div>
          <div class="ml-clinician-meta-line"><span>Specialty</span> <strong>{{ block.settings.specialty }}</strong></div>
          <div class="ml-clinician-meta-line"><span>Years in practice</span> <strong>{{ block.settings.years }}</strong></div>
        </div>
        <div class="ml-clinician-content">
          <h5>{{ block.settings.title }}</h5>
          <p>{{ block.settings.body }}</p>
          {% if block.settings.highlights != blank %}
            <div class="ml-clinician-highlights">
              <span class="h-label">Highlights:</span>
              {% assign highlights = block.settings.highlights | split: ',' %}
              {% for h in highlights %}<span class="h-item">{{ h | strip }}</span>{% endfor %}
            </div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
  <div class="ml-clin-foot">
    <small>Clinician reviews powered by FrontrowMD</small>
  </div>
</section>

