{% render 'maison-vars' %}
<style>
  .ml-embrace { padding: 80px 48px; background: var(--ml-cream); }
  .ml-embrace-grid { max-width: 1080px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1.1fr; gap: 56px; align-items: center; }
  .ml-embrace h2 { font-family: var(--ml-serif); font-size: clamp(34px, 4.5vw, 50px); font-weight: 300; line-height: 1; letter-spacing: -0.02em; color: var(--ml-ink); margin-bottom: 18px; }
  .ml-embrace h2 em { font-style: italic; font-weight: 300; }
  .ml-embrace p { font-size: 14px; color: var(--ml-charcoal); line-height: 1.7; max-width: 460px; }
  .ml-embrace-img { aspect-ratio: 5/4; background: var(--ml-tan); border-radius: 4px; overflow: hidden; }
  .ml-embrace-img img { width: 100%; height: 100%; object-fit: cover; }
  @media (max-width: 900px) {
    .ml-embrace { padding: 56px 20px; }
    .ml-embrace-grid { grid-template-columns: 1fr; gap: 28px; }
  }
</style>
<section class="ml-section ml-embrace">
  <div class="ml-embrace-grid">
    <div>
      <h2>{{ section.settings.heading | default: '<p>Embrace Your Body,<br>Radiate Your <em>Confidence.</em></p>' }}</h2>
      <p>{{ section.settings.body | default: 'Our Magic Body Elixir is your secret weapon for achieving the smooth, toned, and radiant skin you''ve always dreamed of. Packed with powerful natural ingredients like Patchouli, Rosehip and Geranium this silky elixir deeply nourishes, firms, and rejuvenates, helping you rediscover your most confident, sexy self at any age.' }}</p>
    </div>
    <div class="ml-embrace-img">
      {% if section.settings.image %}<img src="{{ section.settings.image | image_url: width: 1400 }}" alt="">{% endif %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Maison Embrace Body",
  "settings": [
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Embrace Your Body,<br>Radiate Your <em>Confidence.</em></p>" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Our Magic Body Elixir is your secret weapon for achieving the smooth, toned, and radiant skin you've always dreamed of." },
    { "type": "image_picker", "id": "image", "label": "Image (real women, group shot)" }
  ],
  "presets": [{ "name": "Maison Embrace Body" }]
}
{% endschema %}
