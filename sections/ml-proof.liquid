{% render 'maison-vars' %}
<style>
  .ml-proof { padding: 96px 48px; background: var(--ml-cream); }
  .ml-proof-grid { max-width: 1180px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1.05fr; gap: 64px; align-items: center; }
  .ml-proof-eyebrow {
    font-family: var(--ml-body);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--ml-brown);
    margin-bottom: 18px;
  }
  .ml-proof h2 {
    font-family: var(--ml-serif);
    font-size: clamp(44px, 5.5vw, 64px);
    font-weight: 300;
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--ml-ink);
    margin-bottom: 24px;
  }
  .ml-proof h2 em { font-style: italic; color: var(--ml-ink); font-weight: 300; }
  .ml-proof-stars { color: var(--ml-honey-deep); font-size: 14px; letter-spacing: 0.1em; margin-bottom: 12px; }
  .ml-proof-product-name {
    font-family: var(--ml-serif);
    font-size: 19px;
    color: var(--ml-ink);
    line-height: 1.3;
    margin-bottom: 8px;
  }
  .ml-proof-product-name .price { color: var(--ml-ink); margin-left: 8px; }
  .ml-proof p { font-size: 14px; color: var(--ml-charcoal); line-height: 1.65; max-width: 440px; margin-bottom: 12px; }
  .ml-proof p.italic { font-style: italic; color: var(--ml-brown); }
  .ml-proof-cta { margin-top: 20px; }

  /* The signature visual — bottle on warm tan with ingredient bubbles floating */
  .ml-proof-visual {
    aspect-ratio: 1;
    background: var(--ml-tan);
    border-radius: 4px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 24px;
  }
  .ml-proof-visual::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 36%;
    background: linear-gradient(180deg, transparent, rgba(61,36,24,0.08));
  }
  .ml-proof-bottle {
    position: relative;
    z-index: 2;
    max-height: 80%;
    max-width: 50%;
    object-fit: contain;
    filter: drop-shadow(0 30px 40px rgba(61,36,24,0.25));
  }
  .ml-proof-bottle-fallback {
    width: 140px;
    height: 320px;
    background: linear-gradient(180deg, #5C2E1A 0%, #2E1408 100%);
    border-radius: 6px 6px 18px 18px;
    position: relative;
    z-index: 2;
    box-shadow: 0 30px 50px rgba(61,36,24,0.4);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .ml-proof-bottle-fallback::before {
    content: '';
    position: absolute;
    top: -28px;
    left: 50%;
    transform: translateX(-50%);
    width: 50px;
    height: 56px;
    background: linear-gradient(180deg, #1A0A04, #000);
    border-radius: 4px 4px 0 0;
  }
  .ml-proof-bottle-label {
    background: var(--ml-cream);
    width: 78%;
    padding: 12px 8px;
    text-align: center;
    font-family: var(--ml-serif);
  }
  .ml-proof-bottle-label .brand { font-size: 17px; color: var(--ml-ink); letter-spacing: 0.05em; line-height: 1; }
  .ml-proof-bottle-label .product { font-size: 11px; color: var(--ml-brown); margin-top: 4px; letter-spacing: 0.04em; }
  .ml-proof-bottle-label .tag { font-size: 7px; letter-spacing: 0.18em; color: var(--ml-honey-deep); margin-top: 6px; text-transform: uppercase; font-family: var(--ml-body); font-weight: 600; }

  /* Ingredient bubbles */
  .ml-ing {
    position: absolute;
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background: var(--ml-cream);
    box-shadow: 0 8px 24px rgba(61,36,24,0.18);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 8px;
  }
  .ml-ing-img { width: 44px; height: 44px; border-radius: 50%; background: var(--ml-tan); margin-bottom: 4px; display: flex; align-items: center; justify-content: center; font-size: 20px; }
  .ml-ing-img img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
  .ml-ing-name { font-family: var(--ml-serif); font-size: 12px; color: var(--ml-ink); letter-spacing: 0.02em; }
  .ml-ing.tl { top: 14%; left: 6%; }
  .ml-ing.tr { top: 14%; right: 6%; }
  .ml-ing.bl { bottom: 22%; left: 6%; }
  .ml-ing.br { bottom: 22%; right: 6%; }

  @media (max-width: 900px) {
    .ml-proof { padding: 64px 20px; }
    .ml-proof-grid { grid-template-columns: 1fr; gap: 36px; }
    .ml-ing { width: 72px; height: 72px; }
    .ml-ing-img { width: 32px; height: 32px; font-size: 14px; }
    .ml-ing-name { font-size: 10px; }
  }
</style>
<section class="ml-section ml-proof">
  <div class="ml-proof-grid">
    <div>
      {% if section.settings.eyebrow != blank %}
        <div class="ml-proof-eyebrow">{{ section.settings.eyebrow }}</div>
      {% endif %}
      <h2>{{ section.settings.heading | default: '<p>Loved by <em>380,000+</em></p>' }}</h2>
      <div class="ml-proof-stars">★★★★★</div>
      {% if section.settings.featured_product %}
        <div class="ml-proof-product-name">
          {{ section.settings.featured_product.title }}
          {% if section.settings.featured_product.price %}<span class="price">{{ section.settings.featured_product.price | money }}</span>{% endif %}
        </div>
      {% endif %}
      <p>{{ section.settings.body | default: 'Centuries of feminine wisdom captured in a single bottle, restoring softness, firmness, and radiance.' }}</p>
      {% if section.settings.body2 != blank %}
        <p class="italic">{{ section.settings.body2 }}</p>
      {% endif %}
      {% if section.settings.cta_text != blank %}
        <div class="ml-proof-cta">
          <a href="{% if section.settings.featured_product %}{{ section.settings.featured_product.url }}{% else %}{{ section.settings.cta_link | default: '/collections/all' }}{% endif %}" class="ml-btn-solid">{{ section.settings.cta_text }}</a>
        </div>
      {% endif %}
    </div>
    <div class="ml-proof-visual">
      {% for block in section.blocks %}
        <div class="ml-ing {{ block.settings.position }}" {{ block.shopify_attributes }}>
          <div class="ml-ing-img">
            {% if block.settings.image %}<img src="{{ block.settings.image | image_url: width: 200 }}" alt="">{% else %}{{ block.settings.emoji | default: '✿' }}{% endif %}
          </div>
          <div class="ml-ing-name">{{ block.settings.name }}</div>
        </div>
      {% endfor %}
      {% if section.settings.featured_product and section.settings.featured_product.featured_image %}
        <img src="{{ section.settings.featured_product.featured_image | image_url: width: 1000 }}" alt="" class="ml-proof-bottle">
      {% elsif section.settings.bottle_image %}
        <img src="{{ section.settings.bottle_image | image_url: width: 1000 }}" alt="" class="ml-proof-bottle">
      {% else %}
        <div class="ml-proof-bottle-fallback">
          <div class="ml-proof-bottle-label">
            <div class="brand">MAISON LUMEN</div>
            <div class="product">Magic Body Elixir</div>
            <div class="tag">Firm · Plump · Hydrate</div>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Maison Proof",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "PURE INGREDIENTS YOUR SKIN SEEKS" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Loved by <em>380,000+</em></p>" },
    { "type": "product", "id": "featured_product", "label": "Featured product" },
    { "type": "image_picker", "id": "bottle_image", "label": "Bottle image (fallback if no product)" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Centuries of feminine wisdom captured in a single bottle, restoring softness, firmness, and radiance." },
    { "type": "textarea", "id": "body2", "label": "Italic line below body", "default": "An ancient formula specially crafted for you." },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Take Me There" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient bubble",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image (optional)" },
        { "type": "text", "id": "emoji", "label": "Or emoji/glyph", "default": "✿" },
        { "type": "text", "id": "name", "label": "Name", "default": "Almond" },
        { "type": "select", "id": "position", "label": "Corner", "default": "tl", "options": [
          { "value": "tl", "label": "Top left" },
          { "value": "tr", "label": "Top right" },
          { "value": "bl", "label": "Bottom left" },
          { "value": "br", "label": "Bottom right" }
        ]}
      ]
    }
  ],
  "presets": [{
    "name": "Maison Proof",
    "blocks": [
      { "type": "ingredient", "settings": { "name": "Almond", "emoji": "🌰", "position": "tl" } },
      { "type": "ingredient", "settings": { "name": "Primrose", "emoji": "✿", "position": "tr" } },
      { "type": "ingredient", "settings": { "name": "Rosehip", "emoji": "🌹", "position": "bl" } },
      { "type": "ingredient", "settings": { "name": "Patchouli", "emoji": "🌿", "position": "br" } }
    ]
  }]
}
{% endschema %}
