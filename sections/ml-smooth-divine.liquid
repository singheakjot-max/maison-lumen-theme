{% render 'maison-vars' %}
<style>
  .ml-divine { padding: 80px 48px; background: var(--ml-cream); }
  .ml-divine-grid { max-width: 1080px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
  .ml-divine h2 { font-family: var(--ml-serif); font-size: clamp(34px, 4.5vw, 50px); font-weight: 300; line-height: 1; letter-spacing: -0.02em; color: var(--ml-ink); margin-bottom: 16px; }
  .ml-divine h2 em { font-style: italic; font-weight: 300; }
  .ml-divine p { font-size: 14px; color: var(--ml-charcoal); line-height: 1.7; max-width: 400px; }
  .ml-divine-visual { background: var(--ml-amber-bg); border-radius: 4px; padding: 40px 32px; aspect-ratio: 1.1; display: flex; flex-direction: column; justify-content: space-between; }
  .ml-divine-visual-head { display: flex; gap: 20px; align-items: center; }
  .ml-divine-visual-head img { max-height: 200px; }
  .ml-divine-visual h3 { font-family: var(--ml-serif); font-size: 26px; font-weight: 300; line-height: 1.1; color: var(--ml-ink); }
  .ml-divine-visual h3 em { font-style: italic; font-weight: 300; }
  .ml-divine-zones { display: flex; gap: 24px; justify-content: space-around; margin-top: 20px; }
  .ml-divine-zone { text-align: center; }
  .ml-divine-zone-svg {
    width: 60px;
    height: 60px;
    margin: 0 auto 6px;
    color: var(--ml-brown);
  }
  .ml-divine-zone-lbl {
    font-family: var(--ml-body);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ml-brown);
    font-weight: 600;
  }
  @media (max-width: 900px) {
    .ml-divine { padding: 56px 20px; }
    .ml-divine-grid { grid-template-columns: 1fr; gap: 32px; }
    .ml-divine-visual { aspect-ratio: auto; padding: 28px 20px; }
  }
</style>
<section class="ml-section ml-divine">
  <div class="ml-divine-grid">
    <div>
      <h2>{{ section.settings.heading | default: '<p>Smooth & Fine.<br>So <em>Divine.</em></p>' }}</h2>
      <p>{{ section.settings.body | default: 'Pure, unadulterated fine ingredients make this body oil suitable for all skin types and ages. Visibly glowing and plumper skin in days.' }}</p>
    </div>
    <div class="ml-divine-visual">
      <div class="ml-divine-visual-head">
        {% if section.settings.bottle_image %}<img src="{{ section.settings.bottle_image | image_url: width: 400 }}" alt="">{% endif %}
        <h3>{{ section.settings.visual_heading | default: '<p>That Firms, Plumps & <em>Hydrates</em></p>' }}</h3>
      </div>
      <div class="ml-divine-zones">
        {% for block in section.blocks %}
          <div class="ml-divine-zone" {{ block.shopify_attributes }}>
            <svg class="ml-divine-zone-svg" viewBox="0 0 60 60" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              {% case block.settings.zone %}
                {% when 'arms' %}
                  <path d="M22 8 L22 38 M38 8 L38 38 M22 38 Q22 50 26 54 M38 38 Q38 50 34 54"/>
                {% when 'chest' %}
                  <path d="M14 18 L46 18 M14 18 Q14 30 22 36 Q30 42 38 36 Q46 30 46 18"/>
                  <path d="M22 24 Q26 27 30 24" /><path d="M30 24 Q34 27 38 24"/>
                {% when 'thighs' %}
                  <path d="M22 6 L22 50 M38 6 L38 50 M18 50 L26 56 M34 56 L42 50"/>
                {% when 'tums' %}
                  <path d="M16 14 Q16 32 30 36 Q44 32 44 14 M22 24 Q30 28 38 24"/>
                {% else %}
                  <circle cx="30" cy="30" r="20"/>
              {% endcase %}
            </svg>
            <div class="ml-divine-zone-lbl">{{ block.settings.label }}</div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Maison Smooth Divine",
  "settings": [
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Smooth & Fine.<br>So <em>Divine.</em></p>" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Pure, unadulterated fine ingredients make this body oil suitable for all skin types and ages." },
    { "type": "richtext", "id": "visual_heading", "label": "Visual heading", "default": "<p>That Firms, Plumps & <em>Hydrates</em></p>" },
    { "type": "image_picker", "id": "bottle_image", "label": "Bottle image (optional)" }
  ],
  "blocks": [
    {
      "type": "zone",
      "name": "Body zone",
      "settings": [
        { "type": "select", "id": "zone", "label": "Zone shape", "default": "arms", "options": [
          { "value": "arms", "label": "Arms" },
          { "value": "chest", "label": "Chest" },
          { "value": "thighs", "label": "Thighs" },
          { "value": "tums", "label": "Tums" }
        ]},
        { "type": "text", "id": "label", "label": "Label", "default": "Arms" }
      ]
    }
  ],
  "presets": [{
    "name": "Maison Smooth Divine",
    "blocks": [
      { "type": "zone", "settings": { "zone": "chest", "label": "Chest" } },
      { "type": "zone", "settings": { "zone": "thighs", "label": "Thighs" } }
    ]
  }]
}
{% endschema %}
