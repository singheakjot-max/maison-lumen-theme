{% render 'maison-vars' %}
<style>
  .ml-split { padding: 0; background: var(--ml-cream); }
  .ml-split.bg-white { background: var(--ml-white); }
  .ml-split.bg-tan { background: var(--ml-tan); }
  .ml-split-inner { max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 0; align-items: stretch; }
  .ml-split.reverse .ml-split-inner { grid-template-columns: 1fr 1fr; direction: rtl; }
  .ml-split.reverse .ml-split-inner > * { direction: ltr; }
  .ml-split-img { aspect-ratio: 4/3; overflow: hidden; background: var(--ml-tan-deep); }
  .ml-split-img img { width: 100%; height: 100%; object-fit: cover; }
  .ml-split-text { padding: 56px 48px; display: flex; flex-direction: column; justify-content: center; }
  .ml-split-eyebrow {
    font-family: var(--ml-body);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--ml-brown);
    margin-bottom: 16px;
  }
  .ml-split h2 {
    font-family: var(--ml-serif);
    font-size: clamp(34px, 4vw, 50px);
    font-weight: 300;
    line-height: 1.0;
    letter-spacing: -0.015em;
    color: var(--ml-ink);
    margin-bottom: 20px;
    max-width: 460px;
  }
  .ml-split h2 em { font-style: italic; font-weight: 300; color: var(--ml-ink); }
  .ml-split-list { margin-bottom: 16px; }
  .ml-split-list li {
    font-size: 14px;
    color: var(--ml-charcoal);
    padding: 4px 0;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .ml-split-list li::before { content: attr(data-icon); font-size: 14px; }
  .ml-split-body { font-size: 14px; color: var(--ml-charcoal); line-height: 1.7; max-width: 440px; margin-bottom: 24px; }
  @media (max-width: 900px) {
    .ml-split-inner, .ml-split.reverse .ml-split-inner { grid-template-columns: 1fr; }
    .ml-split-text { padding: 32px 20px 48px; }
  }
</style>
<section class="ml-section ml-split bg-{{ section.settings.bg }} {% if section.settings.reverse %}reverse{% endif %}">
  <div class="ml-split-inner">
    <div class="ml-split-img">
      {% if section.settings.image %}<img src="{{ section.settings.image | image_url: width: 1600 }}" alt="">{% endif %}
    </div>
    <div class="ml-split-text">
      {% if section.settings.eyebrow != blank %}<div class="ml-split-eyebrow">{{ section.settings.eyebrow }}</div>{% endif %}
      <h2>{{ section.settings.heading | default: '<p>There''s A New Way <em>To Glow.</em></p>' }}</h2>
      {% if section.blocks.size > 0 %}
        <ul class="ml-split-list">
          {% for block in section.blocks %}
            <li data-icon="{{ block.settings.icon | default: '✦' }}" {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
          {% endfor %}
        </ul>
      {% endif %}
      <div class="ml-split-body">{{ section.settings.body | default: 'An ancient ritual of oil care, reimagined. Gently nourishes while drenching skin in moisture, transforming your daily ritual into a deeply sensory experience.' }}</div>
      {% if section.settings.cta_text != blank %}
        <div><a href="{{ section.settings.cta_link | default: '#' }}" class="ml-btn-solid">{{ section.settings.cta_text }}</a></div>
      {% endif %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Maison Lifestyle Split",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "checkbox", "id": "reverse", "label": "Reverse (image right)", "default": false },
    { "type": "select", "id": "bg", "label": "Background", "default": "cream", "options": [
      { "value": "cream", "label": "Cream" },
      { "value": "white", "label": "White" },
      { "value": "tan", "label": "Tan" }
    ]},
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "[A NEW RITUAL]" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>There's A New Way <em>To Glow.</em></p>" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "An ancient ritual of oil care, reimagined. Gently nourishes while drenching skin in moisture." },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Learn More" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "blocks": [
    {
      "type": "list_item",
      "name": "List item",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon/emoji", "default": "✿" },
        { "type": "text", "id": "text", "label": "Text", "default": "Inspired by ancient bathing rituals" }
      ]
    }
  ],
  "presets": [{
    "name": "Maison Lifestyle Split",
    "blocks": [
      { "type": "list_item", "settings": { "icon": "✦", "text": "Inspired by ancient bathing rituals" } },
      { "type": "list_item", "settings": { "icon": "☼", "text": "Suitable for all skin types" } },
      { "type": "list_item", "settings": { "icon": "✿", "text": "Natural & skin-loving ingredients" } }
    ]
  }]
}
{% endschema %}
