{% render 'maison-vars' %}
<style>
  .ml-big-test { padding: 80px 48px; background: var(--ml-white); }
  .ml-big-test-grid { max-width: 1080px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
  .ml-big-test-card {
    background: var(--ml-honey-deep);
    color: var(--ml-cream);
    aspect-ratio: 1;
    border-radius: 4px;
    overflow: hidden;
    position: relative;
    display: flex;
  }
  .ml-big-test-quote {
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    flex: 0 0 60%;
  }
  .ml-big-test-photo {
    flex: 1;
    background: var(--ml-tan-deep);
    background-size: cover;
    background-position: center;
  }
  .ml-big-test-brand { font-family: var(--ml-serif); font-size: 13px; letter-spacing: 0.1em; color: var(--ml-cream); margin-bottom: 16px; }
  .ml-big-test-card blockquote {
    font-family: var(--ml-serif);
    font-size: clamp(20px, 2.2vw, 28px);
    font-weight: 400;
    line-height: 1.2;
    color: var(--ml-cream);
    margin: 0;
  }
  .ml-big-test-card blockquote strong, .ml-big-test-card blockquote .hl {
    background: var(--ml-cream);
    color: var(--ml-ink);
    padding: 0 4px 2px;
    font-weight: 400;
    font-style: italic;
  }
  .ml-big-test-text h2 {
    font-family: var(--ml-serif);
    font-size: clamp(34px, 4vw, 48px);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.015em;
    color: var(--ml-ink);
    margin-bottom: 18px;
  }
  .ml-big-test-text h2 em { font-style: italic; font-weight: 300; }
  .ml-big-test-text p { font-size: 14px; color: var(--ml-charcoal); line-height: 1.7; max-width: 440px; }
  @media (max-width: 900px) {
    .ml-big-test { padding: 56px 20px; }
    .ml-big-test-grid { grid-template-columns: 1fr; gap: 28px; }
    .ml-big-test-card { aspect-ratio: 4/3; }
  }
</style>
<section class="ml-section ml-big-test">
  <div class="ml-big-test-grid">
    <div class="ml-big-test-card">
      <div class="ml-big-test-quote">
        <div class="ml-big-test-brand">MAISON LUMEN</div>
        <blockquote>{{ section.settings.quote | default: '<p>"This body oil smells amazing. <span class="hl">My skin drinks it up</span> and feels <span class="hl">a lot firmer.</span> Dry and loose skin is a thing of the past."</p>' }}</blockquote>
      </div>
      <div class="ml-big-test-photo" {% if section.settings.photo %}style="background-image: url('{{ section.settings.photo | image_url: width: 800 }}');"{% endif %}></div>
    </div>
    <div class="ml-big-test-text">
      <h2>{{ section.settings.heading | default: '<p>Loved by <em>380,000+</em><br>Women Just Like You</p>' }}</h2>
      <p>{{ section.settings.body | default: 'Oils penetrate the skin far deeper than lotions and creams. They provide a nourishment and hydration that is unparalleled. Feel confident in your body through nature''s delights.' }}</p>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Maison Big Testimonial",
  "settings": [
    { "type": "richtext", "id": "quote", "label": "Quote (use <span class=\"hl\">phrase</span> for highlights)", "default": "<p>\"This body oil smells amazing. <span class=\"hl\">My skin drinks it up</span> and feels <span class=\"hl\">a lot firmer.</span> Dry and loose skin is a thing of the past.\"</p>" },
    { "type": "image_picker", "id": "photo", "label": "Customer photo" },
    { "type": "richtext", "id": "heading", "label": "Side heading", "default": "<p>Loved by <em>380,000+</em><br>Women Just Like You</p>" },
    { "type": "textarea", "id": "body", "label": "Side body", "default": "Oils penetrate the skin far deeper than lotions and creams. They provide a nourishment and hydration that is unparalleled." }
  ],
  "presets": [{ "name": "Maison Big Testimonial" }]
}
{% endschema %}
