{% render 'maison-vars' %}
<style>
  .ml-hero { position: relative; min-height: 88vh; background: var(--ml-tan); overflow: hidden; }
  .ml-hero-img { position: absolute; inset: 0; }
  .ml-hero-img img { width: 100%; height: 100%; object-fit: cover; }
  .ml-hero-img.no-img { background: linear-gradient(135deg, var(--ml-tan-deep), var(--ml-sand)); }
  .ml-hero-img.no-img::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 70% 40%, rgba(232,184,113,0.3), transparent 40%),
      radial-gradient(circle at 30% 70%, rgba(61,36,24,0.2), transparent 50%);
  }
  .ml-hero-inner {
    position: relative;
    z-index: 2;
    max-width: 1320px;
    margin: 0 auto;
    padding: 88px 48px 64px;
    min-height: 88vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    color: var(--ml-ink);
  }
  .ml-hero-eyebrow {
    font-family: var(--ml-body);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--ml-ink);
    margin-bottom: 16px;
    opacity: 0.85;
  }
  .ml-hero h1 {
    font-family: var(--ml-serif);
    font-size: clamp(48px, 7vw, 96px);
    font-weight: 300;
    line-height: 1.0;
    letter-spacing: -0.02em;
    margin-bottom: 18px;
    color: var(--ml-ink);
    max-width: 720px;
  }
  .ml-hero h1 em { font-style: italic; font-weight: 300; color: var(--ml-ink); }
  .ml-hero-sub {
    font-size: 15px;
    color: var(--ml-ink);
    line-height: 1.6;
    max-width: 460px;
    margin-bottom: 28px;
    opacity: 0.85;
  }
  .ml-hero-ctas { display: flex; gap: 10px; flex-wrap: wrap; }
  @media (max-width: 900px) {
    .ml-hero { min-height: auto; }
    .ml-hero-inner { padding: 60px 20px 40px; min-height: 80vh; }
    .ml-hero h1 { font-size: 44px; }
  }
</style>
<section class="ml-section ml-hero">
  <div class="ml-hero-img {% unless section.settings.image %}no-img{% endunless %}">
    {% if section.settings.image %}
      <img src="{{ section.settings.image | image_url: width: 2400 }}" alt="">
    {% endif %}
  </div>
  <div class="ml-hero-inner">
    {% if section.settings.eyebrow != blank %}
      <div class="ml-hero-eyebrow">{{ section.settings.eyebrow }}</div>
    {% endif %}
    <h1>{{ section.settings.heading | default: '<p>Live your <em>Maison Lumen</em> life.</p>' }}</h1>
    {% if section.settings.subtitle != blank %}
      <p class="ml-hero-sub">{{ section.settings.subtitle }}</p>
    {% endif %}
    <div class="ml-hero-ctas">
      {% if section.settings.cta_text != blank %}
        <a href="{% if section.settings.featured_product %}{{ section.settings.featured_product.url }}{% else %}{{ section.settings.cta_link | default: '/collections/all' }}{% endif %}" class="ml-btn-solid">{{ section.settings.cta_text }}</a>
      {% endif %}
      {% if section.settings.cta2_text != blank %}
        <a href="{{ section.settings.cta2_link | default: '/pages/about' }}" class="ml-btn-outline">{{ section.settings.cta2_text }}</a>
      {% endif %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Maison Hero",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Hero image (full-bleed)" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "[SPRING SKIN '26]" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Live Your <em>Maison Lumen</em> Life.</p>" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Luxury botanical body care. Pure, unrefined, and unadulterated. This is skincare as nature intended." },
    { "type": "text", "id": "cta_text", "label": "Primary CTA", "default": "Shop All" },
    { "type": "url", "id": "cta_link", "label": "Primary CTA link" },
    { "type": "text", "id": "cta2_text", "label": "Secondary CTA", "default": "About Us" },
    { "type": "url", "id": "cta2_link", "label": "Secondary CTA link" },
    { "type": "product", "id": "featured_product", "label": "Featured product (overrides primary CTA link)" }
  ],
  "presets": [{ "name": "Maison Hero" }]
}
{% endschema %}
