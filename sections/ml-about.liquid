{% render 'maison-vars' %}
<style>
  .ml-about { padding: 80px 48px; background: var(--ml-cream); }
  .ml-about-grid { max-width: 1180px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
  .ml-about-img { aspect-ratio: 4/5; background: var(--ml-tan); border-radius: 4px; overflow: hidden; }
  .ml-about-img img { width: 100%; height: 100%; object-fit: cover; }
  .ml-about-text { padding: 0 20px; }
  .ml-about-eyebrow {
    font-family: var(--ml-body);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--ml-brown);
    margin-bottom: 18px;
  }
  .ml-about h2 {
    font-family: var(--ml-serif);
    font-size: clamp(40px, 5vw, 60px);
    font-weight: 300;
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--ml-ink);
    margin-bottom: 22px;
  }
  .ml-about h2 em { font-style: italic; font-weight: 300; }
  .ml-about h2 .hl {
    background: var(--ml-honey);
    padding: 0 8px 4px;
  }
  .ml-about-body { font-size: 14px; color: var(--ml-charcoal); line-height: 1.7; max-width: 460px; margin-bottom: 24px; }
  @media (max-width: 900px) {
    .ml-about { padding: 56px 20px; }
    .ml-about-grid { grid-template-columns: 1fr; gap: 28px; }
    .ml-about-text { padding: 0; }
  }
</style>
<section class="ml-section ml-about">
  <div class="ml-about-grid">
    <div class="ml-about-img">
      {% if section.settings.image %}<img src="{{ section.settings.image | image_url: width: 1200 }}" alt="">{% endif %}
    </div>
    <div class="ml-about-text">
      {% if section.settings.eyebrow != blank %}<div class="ml-about-eyebrow">{{ section.settings.eyebrow }}</div>{% endif %}
      <h2>{{ section.settings.heading | default: '<p>It''s all about <span class="hl">you</span></p>' }}</h2>
      <div class="ml-about-body">{{ section.settings.body }}</div>
      {% if section.settings.cta_text != blank %}
        <a href="{{ section.settings.cta_link | default: '/pages/about' }}" class="ml-btn-outline">{{ section.settings.cta_text }}</a>
      {% endif %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Maison About",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "ABOUT US" },
    { "type": "richtext", "id": "heading", "label": "Heading (use <span class=\"hl\">word</span> for honey highlight)", "default": "<p>It's all about <span class=\"hl\">you</span></p>" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Maison Lumen was founded to bring traditional, natural, age-old remedies passed down through heritage. Loving nature and everything natural, we are advocates of organic and pure living." },
    { "type": "text", "id": "cta_text", "label": "CTA", "default": "Read More" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "presets": [{ "name": "Maison About" }]
}
{% endschema %}
